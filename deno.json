{
  "name": "@m4rc3l05/denotag",
  "version": "5.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "pre:bundle-islands": "rm -rf ./static/dist && cp deno.json deno.web.json && sed -i 's/\"jsx\": \"precompile\"/\"jsx\": \"react-jsx\"/' deno.web.json",
    "main:bundle-islands": "deno bundle --platform browser --format esm --code-splitting --inline-imports --minify --outdir=./static/dist --config=deno.web.json ./src/islands/**/*.tsx",
    "post:bundle-islands": "rm deno.web.json",
    "bundle-islands": {
      "description": "Bundles app's islands of interactivity",
      "command": "deno task pre:bundle-islands && deno task main:bundle-islands && deno task post:bundle-islands"
    },

    "pre:compile": "rm -rf ./app",
    "main:compile": "deno compile --allow-env=ENV,STATIC_CACHE_KEY --allow-net=127.0.0.1 --cached-only --no-check --include=./static --output=./.bin/denotag src/main.ts",
    "compile": {
      "description": "Compile app into a self containing executable",
      "command": "deno task pre:compile && deno task main:compile",
      "dependencies": ["bundle-islands"]
    },

    "run": {
      "description": "Runs the application",
      "command": "deno run -A --cached-only src/main.ts",
      "dependencies": ["bundle-islands"]
    },

    "pre:sync-myfresh": "mkdir -p src/core",
    "main:sync-myfresh": "CORE_DIR=./src/core deno run --unstable-raw-imports -A --reload https://raw.githubusercontent.com/M4RC3L05/My-fresh/refs/heads/main/sync.ts",
    "sync-myfresh": {
      "description": "Sync core files from my-fresh",
      "command": "deno task pre:sync-myfresh && deno task main:sync-myfresh"
    },

    "check:fmt": {
      "description": "Run formatting checks",
      "command": "deno fmt --check ."
    },
    "check:lint": {
      "description": "Run lint checks",
      "command": "deno lint ."
    },
    "check:check": {
      "description": "Run check checks",
      "command": "deno check ."
    },
    "checks": {
      "description": "Run code checks",
      "dependencies": [
        "check:fmt",
        "check:lint",
        "check:check"
      ]
    }
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.unstable",
      "node",
      "dom"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",

    "strict": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictBindCallApply": true,
    "strictBuiltinIteratorReturn": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true
  },
  "lock": { "frozen": true },
  "unstable": ["raw-imports", "npm-lazy-caching"],
  "lint": {
    "rules": {
      "include": [
        "verbatim-module-syntax"
      ],
      "tags": [
        "recommended",
        "jsx",
        "jsr",
        "react"
      ]
    }
  },
  "minimumDependencyAge": "P7D",
  "imports": {
    "@david/dax": "jsr:@david/dax@0.45.0",
    "@hono/hono": "jsr:@hono/hono@4.12.8",
    "@std/cli": "jsr:@std/cli@1.0.28",
    "@std/fs": "jsr:@std/fs@1.0.23",
    "@std/media-types": "jsr:@std/media-types@1.1.0",
    "@std/path": "jsr:@std/path@1.1.4",
    "node-taglib-sharp": "npm:node-taglib-sharp@6.0.1",
    "preact": "npm:preact@10.29.0",
    "preact-render-to-string": "npm:preact-render-to-string@6.6.6",
    "simpledotcss": "npm:simpledotcss@2.3.7"
  }
}
